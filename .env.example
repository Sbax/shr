# Host port the radio is served on (default 1970).
RADIO_PORT=1970

# Stream metadata shown to listeners.
RADIO_NAME=Self Hosted Radio
RADIO_DESCRIPTION=A self hosted radio, running 24/7.
RADIO_GENRE=Various

# Public hostname of your server, used in the stream URLs shown by Icecast.
ICECAST_HOSTNAME=localhost

# Icecast passwords - CHANGE THESE before going to production!
# ICECAST_SOURCE_PASSWORD is the one Liquidsoap uses to push the stream.
ICECAST_SOURCE_PASSWORD=changeme_source
ICECAST_ADMIN_PASSWORD=changeme_admin
ICECAST_PASSWORD=changeme_master
ICECAST_RELAY_PASSWORD=changeme_relay
